@page
@model IndexModel

<h2>Cidades</h2>

@foreach (var city in Model.Cities)
{
    <h3>@city.Name (@city.Country.CountryName)</h3>

    <ul>
        @foreach (var property in city.Properties)
        {
            <li>
                @property.Name - R$ @property.PricePerNight
            </li>
        }
    </ul>
    
    <a asp-page="/CityDetails" asp-route-name="@city.Name">
        Ver detalhes
    </a>
    
}